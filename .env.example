# OpenCoder Configuration
# Copy this file to .env and fill in your values

# OpenGPU Relay Configuration
OPENGPU_BASE_URL=https://relay.opengpu.network/v1
OPENGPU_API_KEY=your-api-key-here
OPENGPU_MODEL=gpt-4o
OPENGPU_TIMEOUT=120.0
OPENGPU_MAX_TOKENS=4096

# OpenCoder Configuration
OPENCODER_REPO_PATH=./workspace
OPENCODER_READ_ONLY=false

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
